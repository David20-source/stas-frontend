{
  "rewrites": [
    { "source": "/api/auth/register", "destination": "/api/auth/route.js" },
    { "source": "/api/auth/login", "destination": "/api/auth/route.js" },
    { "source": "/api/auth/refresh", "destination": "/api/auth/route.js" },
    { "source": "/api/auth/logout", "destination": "/api/auth/route.js" },
    { "source": "/api/auth/me", "destination": "/api/auth/route.js" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/" }
  ]
}